# ──────────────────────────────────────────────────────────────────────────────
# Crypto Alert System — Environment Variables
# Copy to .env and fill in all required values before running.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────────

# Random 32-byte hex string.  Generate with:  openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Set to true only during local development
DEBUG=false

# Host port to expose the app on
APP_PORT=8000

# ── Database ───────────────────────────────────────────────────────────────────

POSTGRES_DB=crypto_alerts
POSTGRES_USER=crypto_user

# Required — choose a strong password
POSTGRES_PASSWORD=change-me-strong-password

# ── First admin account (created automatically on first run) ───────────────────
# Leave blank to skip auto-creation (useful if registering manually)

FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=ChangeMe1!
FIRST_ADMIN_USERNAME=admin

# Allow new user self-registration (set false after initial setup if desired)
REGISTRATION_ENABLED=true

# ── SMTP (email alerts) ────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com

# Use 465 with SMTP_MODE=ssl, or 587 with SMTP_MODE=starttls
SMTP_PORT=587

# ssl | starttls | none
SMTP_MODE=starttls

SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=alerts@example.com

# ── Alert engine ───────────────────────────────────────────────────────────────

# How often to poll Kraken for prices (seconds)
KRAKEN_POLL_INTERVAL_SECONDS=60

# Minimum time between re-triggering the same alert rule (minutes)
ALERT_COOLDOWN_MINUTES=60

# ── Security ───────────────────────────────────────────────────────────────────

# Failed login attempts before account lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=30

# Set true when running behind a TLS reverse proxy (Caddy, nginx + certbot, etc.)
HTTPS_ONLY=false

# Session timeouts
SESSION_IDLE_TIMEOUT_HOURS=8
SESSION_ABSOLUTE_TIMEOUT_HOURS=168

# ── Asset discovery ────────────────────────────────────────────────────────────

# Allow users to add arbitrary Kraken USD pairs (beyond supported list)
ALLOW_CUSTOM_PAIRS=false

# How many hours to cache the Kraken asset list
KRAKEN_ASSET_CACHE_HOURS=6
